{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "frame-brief.vercel.app" }],
      "destination": "https://framebriefai.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/recall-webhook.js": { "maxDuration": 60 },
    "api/google-calendar-auth.js": { "maxDuration": 30 },
    "api/auth/google-calendar/callback.js": { "maxDuration": 30 }
  }
}
